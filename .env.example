PORT=3000
HOST_PORT=3000
JWT_SECRET=change-me-to-a-long-random-secret
NODE_ENV=development

# Set to true only if serving over HTTPS (e.g. behind a reverse proxy with TLS)
# Leave false for plain HTTP on a local network
COOKIE_SECURE=false

# Backup configuration
# BACKUP_DIR=/app/backups          # path inside container (set by docker-compose)
# BACKUP_CRON=0 2 * * *            # default: every night at 2am
# BACKUP_KEEP_DAYS=30              # how many daily backups to retain

{
  "name": "havoro",
  "version": "1.1.3",
  "description": "Havoro — household finance tracker",
  "main": "main.js",
  "private": true,
  "scripts": {
    "start": "electron .",
    "build": "electron-builder build --config electron-builder.yml",
    "build:win": "electron-builder build --win --config electron-builder.yml",
    "build:linux": "electron-builder build --linux --config electron-builder.yml",
    "rebuild": "electron-rebuild -f -w better-sqlite3 --module-dir ../server"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.6.0",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  }
}
